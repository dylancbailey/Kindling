# Cloudflare Pages reads this file. Long-cache the content-hashed build assets and
# the fonts (their URLs change on every build / never change), so repeat visits are
# instant. Everything else (HTML, /kindle scripts) uses Cloudflare's default
# revalidation so deploys go live immediately.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

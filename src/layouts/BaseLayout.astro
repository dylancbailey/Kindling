---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  ogType?: string;
}
const { title, description, ogType = 'website' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;

// Icon chrome aligned to the centred band: calendar+date (left, today), the
// persistent ember flame (centre, home), a quiet poems link (right). Home is the
// poem of the day, so home ↔ poems is the whole of navigation.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isToday = path === '/';   // home IS the poem of the day
const flame = 'M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Kindling" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <ClientRouter />
  <slot name="head" />
</head>
<body>
  <!-- A full-screen background curtain: covers the page during the intro and on
       every navigation, then fades away to reveal the page. -->
  <div id="curtain" aria-hidden="true"></div>
  <div class="ktop" aria-label="Primary">
    <div class="ktop-left">
      <span class:list={['ktop-cal', { today: isToday }]}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        <span class="ktop-date" id="ktop-date"></span>
        {isToday && <span class="ktop-todaylabel">today's poem</span>}
      </span>
    </div>
    <a class="ktop-center ktop-ember" href="/" aria-label="Kindling home">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d={flame}></path></svg>
    </a>
    <div class="ktop-right">
      <a class:list={['ktop-link', { current: path === '/poems' }]} href="/poems"
         aria-label="The poem collection" title="The collection"
         aria-current={path === '/poems' ? 'page' : undefined}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 5.5 C9.5 4 5.5 4 3.5 4.8 L3.5 18.5 C5.5 17.7 9.5 17.7 12 19.2 C14.5 17.7 18.5 17.7 20.5 18.5 L20.5 4.8 C18.5 4 14.5 4 12 5.5 Z"></path>
          <line x1="12" y1="5.5" x2="12" y2="19.2"></line>
        </svg>
      </a>
    </div>
  </div>
  <script is:inline>
    (function () {
      function fillDate() {
        var el = document.getElementById('ktop-date');
        if (!el) return;
        var d = new Date();
        el.textContent = String(d.getMonth() + 1).padStart(2, '0') + '/' + String(d.getDate()).padStart(2, '0');
      }

      // ── Background curtain (opening intro ONLY) ─────────────
      // The curtain covers the page during the one-time intro flame so the chrome
      // doesn't bleed through. It is NOT used for navigation — layering it over
      // Astro's view transitions made every element flash. Navigations are instant.
      function reveal() { var c = document.getElementById('curtain'); if (c) c.style.opacity = '0'; }
      function settle() {
        fillDate();
        if (!document.getElementById('ticker')) reveal();   // non-typing page: reveal once loaded
        setTimeout(reveal, 3500);                            // safety: never leave the curtain stuck
      }
      window.__kindleReveal = reveal;   // the engine reveals after the intro / poem is in

      // The curtain defaults to hidden (CSS). This block runs only on the GENUINE
      // first load (not navigations, which re-run this script with the flag set), so
      // here — and only here — we cover the curtain for the opening intro.
      if (!window.__kindleChromeInit) {
        window.__kindleChromeInit = true;
        var c0 = document.getElementById('curtain');
        if (c0) { c0.style.transition = 'none'; c0.style.opacity = '1'; void c0.offsetWidth; c0.style.transition = ''; }
        document.addEventListener('astro:page-load', settle);
        document.addEventListener('astro:after-swap', function () {
          window.__kindleNavigated = true;                  // never replay the intro on nav
          var intro = document.getElementById('intro');
          if (intro) intro.classList.add('done');
        });
      }

      fillDate();
    })();
  </script>
  <slot />
</body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const flame = 'M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z';
---
<BaseLayout
  title="Page not found — Kindling"
  description="That page isn't here. Return to today's poem and warm up."
>
  <main class="notfound">
    <span class="nf-flame" aria-hidden="true">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d={flame}></path></svg>
    </span>
    <p class="nf-code">404</p>
    <p class="nf-msg">This page burned out.</p>
    <a class="nf-home" href="/">return to today's poem →</a>
  </main>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCorpus } from '../lib/poems';

// A mini calendar of the current month, centred. The month grid and "today's
// poem" are rendered in the browser (the current date isn't known at build time),
// using the SAME pickTodayIndex / mulberry32 / shuffledIndices logic as
// public/kindle/kindle-page.js — so the poem highlighted here is exactly the
// poem the home page shows today. If that picker ever changes, change it here too.
const { corpus } = await getCorpus();
const calData = corpus.map((p) => ({ slug: p.slug, title: p.title, dayOfYear: p.dayOfYear }));
---
<BaseLayout
  title="Calendar — Kindling"
  description="A poem for every day. Today's poem is lit on the calendar — tap it to start typing."
>
  <main class="calpage">
    <div class="calpage-wrap">
      <div class="calpage-head">
        <div class="ttl">The Calendar</div>
        <div class="sub">Today's poem is lit — tap it to begin</div>
      </div>
      <div class="cal-mount" id="cal-mount" aria-live="polite"></div>
      <noscript>
        <p class="cal-noscript">Today's poem is on the <a href="/">home page</a>.</p>
      </noscript>
    </div>
  </main>

  <footer class="kfooter solo">
    <a class="k-open" href="/poems">the collection</a>
    <span class="k-foot-sep" aria-hidden="true">·</span>
    <a class="k-open" href="https://lannair.app" target="_blank" rel="noopener">get Lannair →</a>
  </footer>

  <script type="application/json" id="cal-data" is:inline set:html={JSON.stringify({ corpus: calData })}></script>

  <script is:inline>
    (function () {
      // ── poem-of-the-day picker — keep byte-identical to kindle-page.js ──
      function dayOfYear(d) {
        var start = new Date(d.getFullYear(), 0, 0);
        return Math.floor((d - start) / 86400000);
      }
      var POTD_ANCHOR = Date.UTC(2026, 5, 11);
      function mulberry32(a) {
        return function () {
          a |= 0; a = (a + 0x6D2B79F5) | 0;
          var t = Math.imul(a ^ (a >>> 15), 1 | a);
          t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        };
      }
      function shuffledIndices(n, cycle) {
        var arr = []; for (var i = 0; i < n; i++) arr[i] = i;
        var rnd = mulberry32((cycle ^ 0x9E3779B9) >>> 0);
        for (var k = n - 1; k > 0; k--) {
          var j = Math.floor(rnd() * (k + 1));
          var tmp = arr[k]; arr[k] = arr[j]; arr[j] = tmp;
        }
        return arr;
      }
      function pickTodayIndex(corpus) {
        var d = new Date();
        var doy = dayOfYear(d);
        for (var i = 0; i < corpus.length; i++) {
          if (corpus[i].dayOfYear === doy) return i;
        }
        var today = Date.UTC(d.getFullYear(), d.getMonth(), d.getDate());
        var dayIdx = Math.floor((today - POTD_ANCHOR) / 86400000);
        var N = corpus.length;
        var cycle = Math.floor(dayIdx / N);
        var pos = ((dayIdx % N) + N) % N;
        return shuffledIndices(N, cycle)[pos];
      }

      function escHtml(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }
      function escAttr(s) { return escHtml(s).replace(/"/g, '&quot;'); }

      function readCorpus() {
        var el = document.getElementById('cal-data');
        if (!el) return null;
        try { var d = JSON.parse(el.textContent || '{}'); return d.corpus || null; } catch (e) { return null; }
      }

      function render() {
        var mountEl = document.getElementById('cal-mount');
        if (!mountEl) return;
        var corpus = readCorpus();
        if (!corpus || !corpus.length) return;

        var now = new Date();
        var year = now.getFullYear(), month = now.getMonth(), todayDate = now.getDate();
        var monthName = now.toLocaleString('en-US', { month: 'long' });
        var startDow = new Date(year, month, 1).getDay();          // 0 = Sunday
        var daysInMonth = new Date(year, month + 1, 0).getDate();

        var idx = pickTodayIndex(corpus);
        var poem = corpus[idx] || null;

        var weekdays = ['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'];
        var html = '';
        html += '<div class="cal-monthbar">' + monthName + ' ' + year + '</div>';
        html += '<div class="cal-grid" role="grid">';
        for (var w = 0; w < 7; w++) html += '<div class="cal-dow" role="columnheader">' + weekdays[w] + '</div>';
        for (var b = 0; b < startDow; b++) html += '<div class="cal-cell cal-empty" aria-hidden="true"></div>';
        for (var day = 1; day <= daysInMonth; day++) {
          if (day === todayDate && poem) {
            html += '<a class="cal-cell cal-today" href="/poem/' + encodeURIComponent(poem.slug) + '"'
                  + ' aria-label="Today, ' + monthName + ' ' + day + ' — ' + escAttr(poem.title) + '. Start typing.">'
                  + '<span class="cal-num">' + day + '</span>'
                  + '<span class="cal-poem">' + escHtml(poem.title) + '</span>'
                  + '</a>';
          } else {
            html += '<div class="cal-cell"><span class="cal-num">' + day + '</span></div>';
          }
        }
        html += '</div>';

        if (poem) {
          html += '<a class="cal-caption" href="/poem/' + encodeURIComponent(poem.slug) + '">'
                + '<span class="cal-cap-label">Today · ' + monthName + ' ' + todayDate + '</span>'
                + '<span class="cal-cap-title">' + escHtml(poem.title) + ' &rarr;</span>'
                + '</a>';
        }

        mountEl.innerHTML = html;
      }

      render();
      if (!window.__kindleCalInit) {
        window.__kindleCalInit = true;
        document.addEventListener('astro:page-load', render);
      }
    })();
  </script>
</BaseLayout>
